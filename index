<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hellenic Score & Tales | Hybrid Strategy Archive</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #c5a059;
            --dark-bg: #0a0a0b;
            --card-bg: #161618;
        }
        body {
            background-color: var(--dark-bg);
            color: #e5e7eb;
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3, .cinzel {
            font-family: 'Cinzel', serif;
            letter-spacing: 0.05em;
        }
        .gold-text { color: var(--gold); }
        .gold-bg { background-color: var(--gold); }
        .gold-border { border-color: var(--gold); }
        
        .glass-card {
            background: var(--card-bg);
            border: 1px solid rgba(197, 160, 89, 0.2);
            border-radius: 12px;
            transition: all 0.3s ease;
        }
        
        input, select {
            background: #242427 !important;
            border: 1px solid #3f3f46 !important;
            color: white !important;
            padding: 0.75rem !important;
            border-radius: 6px !important;
        }
        input:focus { border-color: var(--gold) !important; outline: none; box-shadow: 0 0 0 2px rgba(197, 160, 89, 0.2); }
        
        .published-tag { color: #34d399; font-weight: bold; }
        .draft-tag { color: #fb923c; opacity: 0.7; }

        .custom-checkbox {
            width: 1.25rem;
            height: 1.25rem;
            accent-color: var(--gold);
            cursor: pointer;
        }

        .section-header {
            border-left: 4px solid var(--gold);
            padding-left: 1rem;
            margin-bottom: 1rem;
            background: rgba(197, 160, 89, 0.05);
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
        }

        .thumbnail-frame {
            width: 120px;
            height: 68px;
            border: 1px solid var(--gold);
            border-radius: 4px;
            overflow: hidden;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: transform 0.2s;
        }
        .thumbnail-frame:hover {
            transform: scale(1.05);
            border-color: white;
        }
        .thumbnail-frame img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--dark-bg); }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--gold); }

        .reorder-btn {
            padding: 4px;
            border-radius: 4px;
            transition: all 0.2s;
            color: #444;
        }
        .reorder-btn:hover { color: var(--gold); background: #222; }
        
        .loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.95);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .content-link {
            transition: all 0.2s ease;
            text-decoration: none;
            cursor: pointer;
        }
        .content-link:hover {
            color: var(--gold) !important;
            text-decoration: underline;
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <div id="loader" class="loading-overlay">
        <div class="text-center">
            <div class="inline-block animate-spin text-4xl mb-4">🔱</div>
            <p class="cinzel gold-text tracking-widest text-xs uppercase">ΣΥΓΧΡΟΝΙΣΜΟΣ ΑΡΧΕΙΟΥ...</p>
        </div>
    </div>

    <div class="max-w-7xl mx-auto">
        <!-- Header & DB Management -->
        <div class="flex flex-col md:flex-row justify-between items-start mb-8 gap-4">
            <div class="flex flex-col gap-1">
                <div class="flex items-center gap-2 text-[10px] text-zinc-500 uppercase tracking-widest font-bold">
                    <span>Database Status:</span>
                    <span id="db-status" class="text-emerald-500">Checking...</span>
                </div>
                <div class="flex gap-2 mt-1">
                    <button onclick="exportDatabase()" class="text-[10px] py-1.5 px-4 border border-zinc-800 rounded-md hover:border-gold transition-all text-zinc-400">💾 Export Backup</button>
                    <button onclick="importDatabase()" class="text-[10px] py-1.5 px-4 border border-zinc-800 rounded-md hover:border-gold transition-all text-zinc-400">📂 Restore Archive</button>
                    <input type="file" id="import-input" class="hidden" accept=".json" onchange="handleImport(this)">
                </div>
            </div>
            <div class="text-right hidden md:block">
                <p class="text-[10px] text-zinc-600 uppercase tracking-widest font-bold">Artist Strategy Engine</p>
                <p class="text-xs gold-text cinzel">v7.5 Hybrid Edition</p>
            </div>
        </div>

        <header class="mb-12 text-center border-b border-zinc-800 pb-8">
            <h1 class="text-5xl font-bold gold-text mb-3">HELLENIC SCORE & TALES</h1>
            <p class="text-zinc-500 italic tracking-[0.2em] uppercase text-sm">Strategic Content Archive</p>
        </header>

        <!-- Stats & Add Action -->
        <div class="flex flex-col md:flex-row justify-between items-center gap-6 mb-10">
            <div class="flex gap-8">
                <div class="glass-card px-10 py-5 text-center">
                    <p class="text-[11px] text-zinc-500 uppercase font-black tracking-widest mb-1">Συνολικά Project</p>
                    <p id="stat-total" class="text-4xl font-bold gold-text">0</p>
                </div>
            </div>
            <button id="add-btn" onclick="openModal()" class="w-full md:w-auto px-12 py-5 gold-bg text-black font-black uppercase tracking-widest rounded-lg hover:scale-105 active:scale-95 transition-all shadow-2xl flex items-center gap-3">
                <span class="text-2xl">🔱</span>
                ΔΗΜΙΟΥΡΓΙΑ ΝΕΟΥ PROJECT
            </button>
        </div>

        <!-- Table -->
        <div class="glass-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-zinc-900/80 border-b border-zinc-800 text-zinc-500 text-[11px] uppercase tracking-widest font-black">
                            <th class="p-6 w-16 text-center">#</th>
                            <th class="p-6 w-12 text-center">Σειρά</th>
                            <th class="p-6">Project / Visual Art</th>
                            <th class="p-6">Shorts</th>
                            <th class="p-6">Soundtracks</th>
                            <th class="p-6 text-right">Ενέργειες</th>
                        </tr>
                    </thead>
                    <tbody id="project-list" class="divide-y divide-zinc-800/50">
                        <!-- Content -->
                    </tbody>
                </table>
            </div>
            <div id="empty-state" class="p-24 text-center text-zinc-700 cinzel text-xl hidden">
                The archives are empty. Begin the odyssey.
            </div>
        </div>
    </div>

    <!-- Master Modal -->
    <div id="modal" class="fixed inset-0 bg-black/95 backdrop-blur-md hidden flex items-center justify-center p-4 z-50 overflow-y-auto">
        <div class="glass-card w-full max-w-4xl my-8 bg-zinc-900 border-gold/30">
            <div class="p-6 border-b border-zinc-800 flex justify-between items-center bg-zinc-950/50">
                <h2 id="modal-title" class="text-2xl gold-text cinzel">ΔΙΑΧΕΙΡΙΣΗ PROJECT</h2>
                <button onclick="closeModal()" class="text-zinc-500 hover:text-white transition-colors text-3xl">✕</button>
            </div>
            
            <form id="project-form" class="p-8 space-y-10 max-h-[80vh] overflow-y-auto">
                <input type="hidden" id="edit-id">

                <section>
                    <div class="section-header">
                        <h3 class="gold-text font-bold text-sm tracking-widest uppercase">1. ΚΥΡΙΟ ΒΙΝΤΕΟ (Main Video)</h3>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
                        <div class="md:col-span-5 space-y-1">
                            <label class="text-[10px] text-zinc-500 uppercase font-bold">Τίτλος</label>
                            <input type="text" id="main-title" required class="w-full" placeholder="π.χ. Achilles' Rage">
                        </div>
                        <div class="md:col-span-5 space-y-1">
                            <label class="text-[10px] text-zinc-500 uppercase font-bold">YouTube / VEO Link</label>
                            <input type="url" id="main-link" class="w-full" placeholder="https://youtube.com/watch?v=...">
                        </div>
                        <div class="md:col-span-2 pb-3 flex justify-center">
                            <label class="flex flex-col items-center gap-1 cursor-pointer">
                                <span class="text-[10px] text-zinc-500 uppercase">Live</span>
                                <input type="checkbox" id="main-status" class="custom-checkbox">
                            </label>
                        </div>
                    </div>
                </section>

                <section>
                    <div class="section-header flex justify-between items-center">
                        <h3 class="gold-text font-bold text-sm tracking-widest uppercase">2. SHORTS</h3>
                        <button type="button" onclick="addShortRow()" class="text-[10px] bg-zinc-800 px-4 py-1.5 rounded border border-zinc-700 hover:border-gold transition-all uppercase font-bold tracking-widest">+ ΠΡΟΣΘΗΚΗ SHORT</button>
                    </div>
                    <div id="shorts-container" class="space-y-3"></div>
                </section>

                <section>
                    <div class="section-header flex justify-between items-center">
                        <h3 class="gold-text font-bold text-sm tracking-widest uppercase">3. SOUNDTRACKS</h3>
                        <button type="button" onclick="addSoundtrackRow()" class="text-[10px] bg-zinc-800 px-4 py-1.5 rounded border border-zinc-700 hover:border-gold transition-all uppercase font-bold tracking-widest">+ ΠΡΟΣΘΗΚΗ SCORE</button>
                    </div>
                    <div id="soundtracks-container" class="space-y-3"></div>
                </section>

                <div class="pt-8 border-t border-zinc-800 flex justify-end gap-6">
                    <button type="button" onclick="closeModal()" class="text-zinc-500 hover:text-white uppercase text-xs font-bold tracking-widest">Ακύρωση</button>
                    <button type="submit" class="px-12 py-4 gold-bg text-black font-black rounded hover:brightness-110 transition-all uppercase text-sm tracking-widest shadow-lg">Αποθήκευση στο Αρχείο</button>
                </div>
            </form>
        </div>
    </div>

    <div id="toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 gold-bg text-black px-12 py-5 rounded-full hidden shadow-2xl z-[100] font-black text-xs uppercase tracking-widest">
    </div>

    <script type="module">
        const hasFirebase = typeof __firebase_config !== 'undefined' && __firebase_config !== null;
        const dbStatus = document.getElementById('db-status');
        const loader = document.getElementById('loader');
        
        let projects = [];
        let dbMode = 'local';

        // UI Setup
        window.updateStats = () => { document.getElementById('stat-total').innerText = projects.length; };
        
        window.saveDataLocal = () => {
            if (dbMode === 'local') {
                localStorage.setItem('hst_hybrid_data', JSON.stringify(projects));
            }
        };

        window.getYouTubeId = (url) => {
            if (!url) return null;
            const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?\s*v=|&v=)([^#&?]*).*/;
            const match = url.match(regExp);
            return (match && match[2].length === 11) ? match[2] : null;
        };

        // Main initialization
        const initializeAppMode = async () => {
            if (hasFirebase) {
                try {
                    // Dynamic Imports to avoid SyntaxError inside if block
                    const { initializeApp } = await import("https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js");
                    const { getAuth, signInAnonymously, onAuthStateChanged } = await import("https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js");
                    const { getFirestore, collection, doc, setDoc, deleteDoc, onSnapshot, updateDoc } = await import("https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js");

                    dbMode = 'cloud';
                    dbStatus.innerText = 'Cloud Sync Active';
                    dbStatus.className = 'text-emerald-500';

                    const firebaseConfig = JSON.parse(__firebase_config);
                    const app = initializeApp(firebaseConfig);
                    const auth = getAuth(app);
                    const db = getFirestore(app);
                    const appId = typeof __app_id !== 'undefined' ? __app_id : 'hst-hybrid-archive';

                    signInAnonymously(auth).then(() => {
                        const projectsRef = collection(db, 'artifacts', appId, 'public', 'data', 'projects');
                        onSnapshot(projectsRef, (snapshot) => {
                            projects = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                            projects.sort((a, b) => (b.orderIndex || 0) - (a.orderIndex || 0));
                            renderProjects();
                            updateStats();
                            loader.classList.add('hidden');
                        }, (err) => {
                             console.error("Firestore error:", err);
                             fallbackToLocal();
                        });
                    }).catch(fallbackToLocal);

                    window.deleteProject = async (id) => {
                        if (confirm('Οριστική διαγραφή;')) {
                            await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'projects', id));
                            showToast('DELETED');
                        }
                    };

                    window.moveProject = async (id, direction) => {
                        const index = projects.findIndex(p => p.id === id);
                        if (direction === 'up' && index === 0) return;
                        if (direction === 'down' && index === projects.length - 1) return;
                        const targetIndex = direction === 'up' ? index - 1 : index + 1;
                        const currentItem = projects[index]; const targetItem = projects[targetIndex];
                        await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'projects', currentItem.id), { orderIndex: targetItem.orderIndex || 0 });
                        await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'projects', targetItem.id), { orderIndex: currentItem.orderIndex || 0 });
                    };

                    window.saveProjectToDB = async (id, data) => {
                        await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'projects', id), data);
                    };

                } catch (err) {
                    console.error("Cloud initialization failed:", err);
                    fallbackToLocal();
                }
            } else {
                fallbackToLocal();
            }
        };

        function fallbackToLocal() {
            dbMode = 'local';
            dbStatus.innerText = 'Local App Storage';
            dbStatus.className = 'text-amber-500';
            const localData = localStorage.getItem('hst_hybrid_data');
            projects = localData ? JSON.parse(localData) : [];
            projects.sort((a, b) => (b.orderIndex || 0) - (a.orderIndex || 0));
            renderProjects();
            updateStats();
            setTimeout(() => loader.classList.add('hidden'), 500);

            window.deleteProject = (id) => {
                if (confirm('Οριστική διαγραφή;')) {
                    projects = projects.filter(p => p.id !== id);
                    saveDataLocal();
                    renderProjects();
                    updateStats();
                }
            };

            window.moveProject = (id, direction) => {
                const index = projects.findIndex(p => p.id === id);
                if (direction === 'up' && index === 0) return;
                if (direction === 'down' && index === projects.length - 1) return;
                const targetIndex = direction === 'up' ? index - 1 : index + 1;
                [projects[index].orderIndex, projects[targetIndex].orderIndex] = [projects[targetIndex].orderIndex, projects[index].orderIndex];
                projects.sort((a, b) => b.orderIndex - a.orderIndex);
                saveDataLocal();
                renderProjects();
            };

            window.saveProjectToDB = (id, data) => {
                const index = projects.findIndex(p => p.id === id);
                if (index > -1) projects[index] = { ...data, id };
                else projects.unshift({ ...data, id });
                saveDataLocal();
                renderProjects();
                updateStats();
            };
        }

        window.renderProjects = () => {
            const projectList = document.getElementById('project-list');
            const emptyState = document.getElementById('empty-state');
            if (projects.length === 0) { projectList.innerHTML = ''; emptyState.classList.remove('hidden'); return; }
            emptyState.classList.add('hidden');
            projectList.innerHTML = projects.map((p, index) => {
                const ytId = getYouTubeId(p.mainVideo.link);
                const thumbUrl = ytId ? `https://img.youtube.com/vi/${ytId}/mqdefault.jpg` : null;

                return `
                    <tr class="hover:bg-zinc-800/40 transition-all group">
                        <td class="p-6 text-center text-zinc-600 font-mono text-xs border-r border-zinc-800/30">${index + 1}</td>
                        <td class="p-6 text-center">
                            <div class="flex flex-col gap-1 items-center opacity-20 group-hover:opacity-100 transition-opacity">
                                <button onclick="moveProject('${p.id}', 'up')" class="reorder-btn ${index === 0 ? 'invisible' : ''}">▲</button>
                                <button onclick="moveProject('${p.id}', 'down')" class="reorder-btn ${index === projects.length - 1 ? 'invisible' : ''}">▼</button>
                            </div>
                        </td>
                        <td class="p-6">
                            <div class="flex items-center gap-5">
                                <a href="${p.mainVideo.link}" target="_blank" class="thumbnail-frame shadow-2xl" title="Άνοιγμα Βίντεο">
                                    ${thumbUrl ? `<img src="${thumbUrl}" alt="Thumb">` : `<span class="text-[10px] text-zinc-700 font-bold uppercase tracking-tighter">No Visual</span>`}
                                </a>
                                <div class="overflow-hidden">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="text-[8px] ${p.mainVideo.published ? 'published-tag' : 'draft-tag'}">●</span>
                                        <div class="font-black gold-text text-base uppercase tracking-tight truncate max-w-[250px] leading-tight">${p.mainVideo.title}</div>
                                    </div>
                                    <a href="${p.mainVideo.link}" target="_blank" class="text-[10px] text-zinc-600 font-mono hover:text-gold transition-colors truncate block max-w-[200px]">
                                        ${p.mainVideo.link || 'Χωρίς Σύνδεσμο'}
                                    </a>
                                </div>
                            </div>
                        </td>
                        <td class="p-6">
                            <div class="space-y-2">
                                ${p.shorts.length > 0 ? p.shorts.map(s => `
                                    <div class="text-[11px] flex items-center gap-2.5">
                                        <span class="${s.published ? 'text-emerald-500 font-bold' : 'text-zinc-700'}">✓</span>
                                        ${s.link ? `<a href="${s.link}" target="_blank" class="text-zinc-400 content-link truncate max-w-[140px] italic underline decoration-zinc-800">${s.title}</a>` : `<span class="text-zinc-600 truncate max-w-[140px]">${s.title}</span>`}
                                    </div>
                                `).join('') : '<span class="text-zinc-800 text-[10px] italic">No Shorts</span>'}
                            </div>
                        </td>
                        <td class="p-6">
                            <div class="space-y-2">
                                ${p.soundtracks.length > 0 ? p.soundtracks.map(st => `
                                    <div class="text-[11px] flex items-center gap-2.5">
                                        <span class="${st.published ? 'text-emerald-500 font-bold' : 'text-zinc-700'}">✓</span>
                                        ${st.link ? `<a href="${st.link}" target="_blank" class="text-zinc-400 content-link truncate max-w-[140px] italic underline decoration-zinc-800">${st.title}</a>` : `<span class="text-zinc-600 truncate max-w-[140px]">${st.title}</span>`}
                                    </div>
                                `).join('') : '<span class="text-zinc-800 text-[10px] italic">No Scores</span>'}
                            </div>
                        </td>
                        <td class="p-6 text-right">
                            <div class="flex justify-end gap-5 opacity-10 group-hover:opacity-100 transition-opacity">
                                <button onclick="openModal('${p.id}')" class="text-[10px] font-black uppercase hover:text-gold tracking-[0.2em] transition-colors">Edit</button>
                                <button onclick="deleteProject('${p.id}')" class="text-[10px] font-black uppercase hover:text-red-600 tracking-[0.2em] transition-colors">Delete</button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
        };

        window.openModal = function(id = null) {
            const form = document.getElementById('project-form');
            form.reset();
            document.getElementById('shorts-container').innerHTML = ''; 
            document.getElementById('soundtracks-container').innerHTML = '';
            document.getElementById('edit-id').value = id || '';
            
            if (id) {
                const p = projects.find(item => item.id === id);
                document.getElementById('main-title').value = p.mainVideo.title;
                document.getElementById('main-link').value = p.mainVideo.link;
                document.getElementById('main-status').checked = p.mainVideo.published;
                p.shorts.forEach(s => addShortRow(s));
                p.soundtracks.forEach(st => addSoundtrackRow(st));
                document.getElementById('modal-title').innerText = "ΕΠΕΞΕΡΓΑΣΙΑ PROJECT";
            } else {
                document.getElementById('modal-title').innerText = "ΝΕΟ EPIC PROJECT";
                addShortRow(); addSoundtrackRow();
            }
            document.getElementById('modal').classList.remove('hidden');
        };

        window.closeModal = () => document.getElementById('modal').classList.add('hidden');

        window.addShortRow = function(data = {title: '', link: '', published: false}) {
            const div = document.createElement('div');
            div.className = "grid grid-cols-1 md:grid-cols-12 gap-3 items-center bg-zinc-800/20 p-3 rounded-lg border border-zinc-800/50";
            div.innerHTML = `
                <div class="md:col-span-5"><input type="text" placeholder="Τίτλος Short" class="w-full short-title" value="${data.title}"></div>
                <div class="md:col-span-5"><input type="url" placeholder="YouTube Link" class="w-full short-link" value="${data.link}"></div>
                <div class="md:col-span-1 flex justify-center"><input type="checkbox" class="custom-checkbox short-status" ${data.published ? 'checked' : ''}></div>
                <div class="md:col-span-1 text-right"><button type="button" onclick="this.parentElement.parentElement.remove()" class="text-zinc-600 hover:text-red-500 transition-colors">✕</button></div>
            `;
            document.getElementById('shorts-container').appendChild(div);
        };

        window.addSoundtrackRow = function(data = {title: '', link: '', published: false}) {
            const div = document.createElement('div');
            div.className = "grid grid-cols-1 md:grid-cols-12 gap-3 items-center bg-zinc-800/20 p-3 rounded-lg border border-zinc-800/50";
            div.innerHTML = `
                <div class="md:col-span-5"><input type="text" placeholder="Τίτλος Soundtrack" class="w-full st-title" value="${data.title}"></div>
                <div class="md:col-span-5"><input type="url" placeholder="Link" class="w-full st-link" value="${data.link}"></div>
                <div class="md:col-span-1 flex justify-center"><input type="checkbox" class="custom-checkbox st-status" ${data.published ? 'checked' : ''}></div>
                <div class="md:col-span-1 text-right"><button type="button" onclick="this.parentElement.parentElement.remove()" class="text-zinc-600 hover:text-red-500 transition-colors">✕</button></div>
            `;
            document.getElementById('soundtracks-container').appendChild(div);
        };

        document.getElementById('project-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const editId = document.getElementById('edit-id').value;
            const id = editId || Date.now().toString();
            
            const shorts = Array.from(document.getElementById('shorts-container').children).map(row => ({
                title: row.querySelector('.short-title').value, link: row.querySelector('.short-link').value, published: row.querySelector('.short-status').checked
            })).filter(s => s.title);
            
            const soundtracks = Array.from(document.getElementById('soundtracks-container').children).map(row => ({
                title: row.querySelector('.st-title').value, link: row.querySelector('.st-link').value, published: row.querySelector('.st-status').checked
            })).filter(st => st.title);

            const maxOrder = projects.length > 0 ? Math.max(...projects.map(p => p.orderIndex || 0)) : 0;
            const orderIndex = editId ? projects.find(p => p.id === editId).orderIndex : (maxOrder + 1);

            const projectData = {
                mainVideo: { title: document.getElementById('main-title').value, link: document.getElementById('main-link').value, published: document.getElementById('main-status').checked },
                shorts, soundtracks, orderIndex, date: editId ? projects.find(p => p.id === editId).date : new Date().toISOString()
            };

            await window.saveProjectToDB(id, projectData);
            showToast('PROJECT SAVED');
            closeModal();
        });

        window.showToast = function(msg) {
            const toast = document.getElementById('toast');
            toast.innerText = msg; toast.classList.remove('hidden');
            setTimeout(() => toast.classList.add('hidden'), 3000);
        };

        window.exportDatabase = function() {
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(projects, null, 2));
            const dl = document.createElement('a'); dl.setAttribute("href", dataStr);
            dl.setAttribute("download", `hst_archive_v7_5_${new Date().toISOString().split('T')[0]}.json`);
            document.body.appendChild(dl); dl.click(); dl.remove();
        };

        window.importDatabase = () => document.getElementById('import-input').click();
        window.handleImport = (input) => {
            const file = input.files[0]; if (!file) return;
            const reader = new FileReader(); reader.onload = async (e) => {
                try {
                    const imported = JSON.parse(e.target.result);
                    if (Array.isArray(imported)) {
                        for (let p of imported) await window.saveProjectToDB(p.id || Date.now() + Math.random(), p);
                        showToast('RESTORE COMPLETE');
                    }
                } catch (err) { alert('Format Error.'); }
            }; reader.readAsText(file);
        };

        // Start app
        initializeAppMode();
    </script>

